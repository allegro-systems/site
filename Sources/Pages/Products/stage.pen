                    },
                    {
                      "type": "text",
                      "id": "7LaL1",
                      "name": "artTitle",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Building a Second Brain with Digital Gardens",
                      "lineHeight": 1.2,
                      "fontFamily": "Fraunces",
                      "fontSize": 36,
                      "fontWeight": "700"
                    },
                    {
                      "type": "frame",
                      "id": "bVlES",
                      "name": "artContent",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "mjCDs",
                          "name": "p1",
                          "fill": "$--text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The concept of a digital garden has been gaining traction among knowledge workers, writers, and developers who want a more organic way to cultivate their ideas. Unlike a traditional blog with its reverse-chronological stream, a digital garden is a collection of evolving notes and essays at various stages of completion.",
                          "lineHeight": 1.7,
                          "fontFamily": "DM Sans",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GjLEf",
                          "name": "p2",
                          "fill": "$--text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "What makes this approach powerful is the shift from performative to exploratory writing. You're not publishing a finished piece — you're tending a living document. Ideas can be seedlings, budding thoughts, or fully mature essays. The garden metaphor gives us permission to share work in progress.",
                          "lineHeight": 1.7,
                          "fontFamily": "DM Sans",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "mB2jR",
                          "name": "p3",
                          "fill": "$--text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Tools like Obsidian, Notion, and Logseq have made it easier than ever to build interconnected knowledge bases. But the real magic happens when you make parts of your second brain public — creating a network of ideas that others can explore and build upon.",
                          "lineHeight": 1.7,
                          "fontFamily": "DM Sans",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    },
