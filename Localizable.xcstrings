    "libretto.feature.discovery.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Autoren folgen, Leselisten kuratieren und Beiträge durch Tags und Empfehlungen hervorheben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Follow writers, curate reading lists, and surface posts through tags and recommendations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue escritores, cura listas de lectura y muestra publicaciones a través de etiquetas y recomendaciones."
          }
        }
      }
    },
