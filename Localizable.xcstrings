            "state": "translated",
            "value": "Swift-Anwendungen mit einem einzigen Befehl bereitstellen. Keine Konfigurationsdateien, kein Boilerplate."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deploy Swift applications with a single command. No configuration files, no boilerplate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despliega aplicaciones Swift con un solo comando. Sin archivos de configuración, sin plantilla."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Развёртывайте Swift-приложения одной командой. Никаких файлов конфигурации, никакого шаблонного кода."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Distribuisci applicazioni Swift con un singolo comando. Nessun file di configurazione, nessun boilerplate."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déployez des applications Swift avec une seule commande. Pas de fichiers de configuration, pas de boilerplate."
          }
        }
      }
    },
