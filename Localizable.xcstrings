    "score.feature.theme.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Farben, Schriften, Abstände und Dark Mode einmal einstellen. Jede Komponente übernimmt sie automatisch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set colours, fonts, spacing, and dark mode once. Every component picks them up automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura colores, fuentes, espaciado y modo oscuro una vez. Cada componente los recoge automáticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задайте цвета, шрифты, отступы и тёмный режим один раз. Все компоненты подхватят их автоматически."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta colori, font, spaziatura e modalità scura una volta. Ogni componente li adotta automaticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez couleurs, polices, espacement et mode sombre une fois. Chaque composant les adopte automatiquement."
          }
        }
      }
    },
