    "about.standard.zeroconfig.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit sinnvollen Standardwerten ausliefern. Konfiguration ist für Änderungen, nicht für die Einrichtung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ship with sensible defaults. Configuration is for overrides, not setup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía con valores predeterminados sensatos. La configuración es para sobreescrituras, no para inicialización."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поставляйте с разумными значениями по умолчанию. Конфигурация — для переопределений, не для настройки."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Distribuisci con valori predefiniti sensati. La configurazione è per le personalizzazioni, non per il setup."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Livrez avec des valeurs par défaut sensées. La configuration sert aux personnalisations, pas à l'installation."
          }
        }
      }
    },
