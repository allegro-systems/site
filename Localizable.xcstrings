    "stage.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Hosting- und Betriebsschicht des Allegro-Ökosystems — Score-Anwendungen ohne Konfiguration bereitstellen, skalieren und überwachen. Swift-Workloads als erstklassiges Bereitstellungsziel, von statischer Ausgabe bis zu vollständigen Laufzeit-Binärdateien. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hosting and operations layer for the Allegro ecosystem — deploy, scale, and observe Score applications with zero configuration. Swift workloads as a first-class deployment target, from static output to full runtime binaries. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La capa de alojamiento y operaciones del ecosistema Allegro — despliega, escala y observa aplicaciones Score sin configuración. Cargas de trabajo Swift como objetivo de despliegue de primera clase, desde salida estática hasta binarios completos. Próximamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слой хостинга и операций для экосистемы Allegro — развёртывайте, масштабируйте и мониторьте приложения Score без конфигурации. Swift-нагрузки как первоклассная цель развёртывания, от статики до полных бинарных файлов. Скоро."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il livello di hosting e operazioni per l'ecosistema Allegro — deploy, scala e monitora le applicazioni Score senza configurazione. Workload Swift come target di deployment di prima classe, dall'output statico ai binari runtime completi. In arrivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La couche d'hébergement et d'opérations pour l'écosystème Allegro — déployez, scalez et observez les applications Score sans configuration. Les charges Swift comme cible de déploiement de première classe, de la sortie statique aux binaires runtime complets. Bientôt disponible."
          }
        }
      }
    },
