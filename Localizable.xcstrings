    "libretto.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Blogging-Plattform für Entwickler und technische Autoren — angetrieben von Score und Stage. Ein reichhaltiges Bearbeitungserlebnis, ablenkungsfrei, und darauf ausgelegt, Ihre Ideen zu den richtigen Menschen zu bringen. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A blogging platform built for developers and technical writers — powered by Score and Stage. A rich editing experience, distraction-free, and designed to let your ideas reach the right people. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una plataforma de blogs para desarrolladores y escritores técnicos — impulsada por Score y Stage. Una experiencia de edición enriquecida, sin distracciones, diseñada para que tus ideas lleguen a las personas adecuadas. Próximamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Платформа для блогов, созданная для разработчиков и технических писателей — на базе Score и Stage. Богатый опыт редактирования, без отвлечений, спроектирован, чтобы ваши идеи дошли до нужных людей. Скоро."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una piattaforma di blogging per sviluppatori e scrittori tecnici — powered by Score e Stage. Un'esperienza di editing ricca, senza distrazioni, progettata per far arrivare le tue idee alle persone giuste. In arrivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une plateforme de blogging pour les développeurs et rédacteurs techniques — propulsée par Score et Stage. Une expérience d'édition riche, sans distraction, conçue pour que vos idées atteignent les bonnes personnes. Bientôt disponible."
          }
        }
      }
    },
    "libretto.feature.analytics": {
