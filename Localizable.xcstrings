    "score.feature.pages.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Layouts, Komponenten und Inhalte mit Swift Result-Buildern definieren. Keine Templates oder String-Manipulation."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Define layouts, components, and content with Swift result builders. No templates or string wrangling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Define maquetaciones, componentes y contenido con result builders de Swift. Sin plantillas ni manipulación de cadenas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Определяйте макеты, компоненты и контент с помощью Swift result builders. Никаких шаблонов и манипуляций со строками."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Definisci layout, componenti e contenuti con i result builder di Swift. Nessun template o manipolazione di stringhe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez layouts, composants et contenus avec les result builders Swift. Pas de templates ni de manipulation de chaînes."
          }
        }
      }
    },
    "score.feature.persistence": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Integrierte Persistenz"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built-in Persistence"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Persistencia Integrada"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встроенная персистентность"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Persistenza Integrata"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Persistance Intégrée"
          }
        }
      }
    },
    "score.feature.persistence.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten speichern und abfragen ohne externes ORM. Entitäten, Migrationen und Abfragen sind Teil des Frameworks."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Store and query data without bolting on an ORM. Entities, migrations, and queries are part of the framework."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Almacena y consulta datos sin necesidad de un ORM externo. Entidades, migraciones y consultas son parte del framework."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Храните и запрашивайте данные без подключения ORM. Сущности, миграции и запросы — часть фреймворка."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Memorizza e interroga dati senza aggiungere un ORM. Entità, migrazioni e query fanno parte del framework."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stockez et interrogez des données sans ajouter d'ORM. Entités, migrations et requêtes font partie du framework."
          }
        }
      }
    },
    "score.feature.reactive": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaktive UI"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reactive UI"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Interfaz Reactiva"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Реактивный UI"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "UI Reattiva"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "UI Réactive"
          }
        }
      }
    },
    "score.feature.reactive.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Interaktive Elemente mit Signalen hinzufügen. State-Änderungen aktualisieren die Seite sofort, kein vollständiger Reload nötig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add interactive elements with signals. State changes update the page instantly, no full reload needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade elementos interactivos con señales. Los cambios de estado actualizan la página al instante, sin recarga completa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляйте интерактивные элементы с помощью сигналов. Изменения состояния обновляют страницу мгновенно, без полной перезагрузки."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi elementi interattivi con i segnali. I cambiamenti di stato aggiornano la pagina istantaneamente, senza ricaricamento completo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des éléments interactifs avec les signaux. Les changements d'état mettent à jour la page instantanément, sans rechargement complet."
          }
        }
      }
    },
    "score.feature.theme": {
      "localizations": {
