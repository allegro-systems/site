    "score.feature.auth.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Login, Sessions und Route-Guards mit wenigen Zeilen hinzufügen. Anbieter-Integrationen kümmern sich um die Details."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add login, sessions, and route guards with a few lines. Vendor integrations handle the provider details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade inicio de sesión, sesiones y protecciones de ruta con pocas líneas. Las integraciones manejan los detalles del proveedor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте логин, сессии и защиту маршрутов в несколько строк. Интеграции с провайдерами берут на себя детали."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi login, sessioni e protezione delle route con poche righe. Le integrazioni gestiscono i dettagli del provider."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez login, sessions et protection des routes en quelques lignes. Les intégrations gèrent les détails du fournisseur."
          }
        }
      }
    },
    "score.feature.deploy": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Als Statisch oder Server ausliefern"
          }
        },
