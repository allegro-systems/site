    "score.feature.auth": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifizierung Inklusive"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auth Out of the Box"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Autenticación Incluida"
          }
        }
      }
    },
    "score.feature.auth.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Login, Sessions und Route-Guards mit wenigen Zeilen hinzufügen. Anbieter-Integrationen kümmern sich um die Details."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add login, sessions, and route guards with a few lines. Vendor integrations handle the provider details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade inicio de sesión, sesiones y protecciones de ruta con pocas líneas. Las integraciones manejan los detalles del proveedor."
          }
        }
      }
    },
    "score.feature.deploy": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Als Statisch oder Server ausliefern"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ship as Static or Server"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Publica como Estático o Servidor"
          }
        }
      }
    },
    "score.feature.deploy.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine statische Website generieren oder einen Live-Server aus derselben Codebasis betreiben. Ein Befehl in jedem Fall."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generate a static site or run a live server from the same codebase. One command either way."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Genera un sitio estático o ejecuta un servidor en vivo desde la misma base de código. Un comando en cualquier caso."
          }
        }
      }
    },
    "score.feature.pages": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Seiten in Swift schreiben"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write Pages in Swift"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe Páginas en Swift"
          }
        }
      }
    },
    "score.feature.pages.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Layouts, Komponenten und Inhalte mit Swift Result-Buildern definieren. Keine Templates oder String-Manipulation."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Define layouts, components, and content with Swift result builders. No templates or string wrangling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Define maquetaciones, componentes y contenido con result builders de Swift. Sin plantillas ni manipulación de cadenas."
          }
        }
      }
    },
    "score.feature.persistence": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Integrierte Persistenz"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built-in Persistence"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Persistencia Integrada"
          }
        }
      }
    },
    "score.feature.persistence.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten speichern und abfragen ohne externes ORM. Entitäten, Migrationen und Abfragen sind Teil des Frameworks."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Store and query data without bolting on an ORM. Entities, migrations, and queries are part of the framework."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Almacena y consulta datos sin necesidad de un ORM externo. Entidades, migraciones y consultas son parte del framework."
          }
        }
      }
    },
    "score.feature.reactive": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaktive UI"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reactive UI"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Interfaz Reactiva"
          }
        }
      }
    },
    "score.feature.reactive.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Interaktive Elemente mit Signalen hinzufügen. State-Änderungen aktualisieren die Seite sofort, kein vollständiger Reload nötig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add interactive elements with signals. State changes update the page instantly, no full reload needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade elementos interactivos con señales. Los cambios de estado actualizan la página al instante, sin recarga completa."
          }
        }
      }
    },
    "score.feature.theme": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmäßig Thematisierbar"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Themeable by Default"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tematizable por Defecto"
          }
        }
      }
    },
    "score.feature.theme.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Farben, Schriften, Abstände und Dark Mode einmal einstellen. Jede Komponente übernimmt sie automatisch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set colours, fonts, spacing, and dark mode once. Every component picks them up automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura colores, fuentes, espaciado y modo oscuro una vez. Cada componente los recoge automáticamente."
          }
        }
      }
    },
