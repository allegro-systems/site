    "home.feature.swift_first.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von Grund auf in Swift gebaut. Keine Wrapper, keine Kompromisse — native Leistung und Typsicherheit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built from the ground up in Swift. No wrappers, no compromises — just native performance and type safety."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construido desde cero en Swift. Sin envoltorios, sin compromisos — rendimiento nativo y seguridad de tipos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Построен с нуля на Swift. Без обёрток, без компромиссов — нативная производительность и безопасность типов."
          }
        }
      }
    },
    "home.hero.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Swift-natives Ökosystem von Werkzeugen zum Erstellen, Hosten und Veröffentlichen im modernen Web."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Swift-first ecosystem of tools for building, hosting, and publishing on the modern web."
          }
        },
        "es": {
