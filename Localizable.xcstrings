    "stage.capabilities": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statische Ausgabe hosten  ·  Laufzeit-Binärdateien hosten  ·  Swift-Workloads als erstklassiges Ziel"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Host Static Output  ·  Host Runtime Binaries  ·  Swift Workloads as First-Class Target"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloja Salida Estática  ·  Aloja Binarios  ·  Cargas Swift como Objetivo de Primera Clase"
          }
        }
      }
    },
    "stage.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Hosting- und Betriebsschicht des Allegro-Ökosystems — Score-Anwendungen ohne Konfiguration bereitstellen, skalieren und überwachen. Swift-Workloads als erstklassiges Bereitstellungsziel, von statischer Ausgabe bis zu vollständigen Laufzeit-Binärdateien. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hosting and operations layer for the Allegro ecosystem — deploy, scale, and observe Score applications with zero configuration. Swift workloads as a first-class deployment target, from static output to full runtime binaries. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La capa de alojamiento y operaciones del ecosistema Allegro — despliega, escala y observa aplicaciones Score sin configuración. Cargas de trabajo Swift como objetivo de despliegue de primera clase, desde salida estática hasta binarios completos. Próximamente."
          }
        }
      }
    },
    "stage.feature.deploy": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereitstellung ohne Konfiguration"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero-Config Deploys"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despliegues Sin Configuración"
          }
        }
      }
    },
    "stage.feature.deploy.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Swift-Anwendungen mit einem einzigen Befehl bereitstellen. Keine Konfigurationsdateien, kein Boilerplate."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deploy Swift applications with a single command. No configuration files, no boilerplate."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despliega aplicaciones Swift con un solo comando. Sin archivos de configuración, sin plantilla."
          }
        }
      }
    },
