          }
        }
      }
    },
    "about.principle.composition": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komposition statt Vererbung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Composition over inheritance"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Composición sobre herencia"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Композиция вместо наследования"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Composizione invece di ereditarietà"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Composition plutôt qu'héritage"
          }
        }
      }
    },
    "about.principle.composition.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komplexes Verhalten aus kleinen, vorhersehbaren Teilen aufbauen statt tiefer Klassenhierarchien."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Build complex behavior from small, predictable parts rather than deep class hierarchies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construye comportamiento complejo a partir de partes pequeñas y predecibles en lugar de jerarquías profundas de clases."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создавайте сложное поведение из маленьких, предсказуемых частей, а не из глубоких иерархий классов."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Costruisci comportamenti complessi da parti piccole e prevedibili invece di gerarchie di classi profonde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Construisez des comportements complexes à partir de petites parties prévisibles plutôt que de hiérarchies de classes profondes."
          }
        }
      }
    },
    "about.principle.convention": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konvention statt Konfiguration"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Convention over configuration"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convención sobre configuración"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соглашения вместо конфигурации"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Convenzione invece di configurazione"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Convention plutôt que configuration"
          }
        }
      }
    },
    "about.principle.convention.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sinnvolle Standardwerte, die 90% der Fälle abdecken. Ausweichmöglichkeiten für den Rest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensible defaults that cover 90% of cases. Escape hatches for the rest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Valores predeterminados sensatos que cubren el 90% de los casos. Vías de escape para el resto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разумные значения по умолчанию, покрывающие 90% случаев. Запасные выходы для остального."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Valori predefiniti sensati che coprono il 90% dei casi. Vie d'uscita per il resto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des valeurs par défaut sensées qui couvrent 90% des cas. Des échappatoires pour le reste."
          }
        }
      }
    },
    "about.principle.durability": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Haltbarkeit statt Neuheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Durability over novelty"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Durabilidad sobre novedad"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Надёжность вместо новизны"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Durabilità invece di novità"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durabilité plutôt que nouveauté"
          }
        }
      }
    },
    "about.principle.durability.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie langweilige Technologie, die zuverlässig funktioniert, statt glänzender Tools, die möglicherweise nicht bestehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose boring technology that works reliably over shiny tools that may not last."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige tecnología aburrida que funcione de forma fiable sobre herramientas brillantes que pueden no durar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбирайте скучные технологии, которые работают надёжно, вместо блестящих инструментов, которые могут не прижиться."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli tecnologie consolidate che funzionano in modo affidabile rispetto a strumenti brillanti che potrebbero non durare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez des technologies éprouvées qui fonctionnent de manière fiable plutôt que des outils brillants qui pourraient ne pas durer."
          }
        }
      }
    },
    "about.principle.integration": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertikale Integration statt Klebstoff"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertical integration over glue"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Integración vertical sobre pegamento"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вертикальная интеграция вместо склейки"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Integrazione verticale invece di codice collante"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Intégration verticale plutôt que code de liaison"
          }
        }
      }
    },
    "about.principle.integration.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den gesamten Stack vom Quellcode bis zur Bereitstellung besitzen. Weniger Nahtstellen, weniger Fehler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Own the full stack from source to deployment. Fewer seams, fewer bugs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla todo el stack desde el código fuente hasta el despliegue. Menos uniones, menos errores."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Владейте полным стеком от исходного кода до развёртывания. Меньше стыков — меньше ошибок."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Possiedi l'intero stack dal sorgente al deployment. Meno giunture, meno bug."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maîtrisez toute la pile du code source au déploiement. Moins de jointures, moins de bugs."
          }
        }
      }
    },
    "about.principle.static": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statische Analyse statt Laufzeitprüfungen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Static analysis over runtime checks"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Análisis estático sobre verificaciones en ejecución"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Статический анализ вместо проверок во время выполнения"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Analisi statica invece di controlli a runtime"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Analyse statique plutôt que vérifications à l'exécution"
          }
        }
      }
    },
    "about.principle.static.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fehler zur Kompilierzeit erkennen. Typsicherheit ist die erste Verteidigungslinie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Catch errors at compile time. Type safety is the first line of defense."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecta errores en tiempo de compilación. La seguridad de tipos es la primera línea de defensa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ловите ошибки на этапе компиляции. Безопасность типов — первая линия обороны."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cattura gli errori a tempo di compilazione. La sicurezza dei tipi è la prima linea di difesa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Détectez les erreurs à la compilation. La sûreté des types est la première ligne de défense."
          }
        }
      }
    },
    "about.principle.transparency": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparenz statt Magie"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparency over magic"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparencia sobre magia"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прозрачность вместо магии"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trasparenza invece di magia"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparence plutôt que magie"
          }
        }
      }
    },
    "about.principle.transparency.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Abstraktion sollte inspizierbar sein. Kein verstecktes Laufzeitverhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every abstraction should be inspectable. No hidden runtime behavior."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toda abstracción debe ser inspeccionable. Sin comportamiento oculto en tiempo de ejecución."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждая абстракция должна быть инспектируемой. Никакого скрытого поведения во время выполнения."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni astrazione dovrebbe essere ispezionabile. Nessun comportamento nascosto a runtime."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
