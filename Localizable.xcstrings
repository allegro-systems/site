    "about.avoid.spinners": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladebalken"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Loading spinners"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Indicadores de carga"
          }
        }
      }
    },
    "about.avoid.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Muster, die wir bewusst ablehnen. Nicht weil sie immer falsch sind,\nsondern weil sie im Widerspruch zu der Erfahrung stehen, die wir aufbauen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Patterns we consciously reject. Not because they're always wrong,\nbut because they conflict with the experience we're building."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrones que rechazamos conscientemente. No porque siempre estén mal,\nsino porque entran en conflicto con la experiencia que estamos construyendo."
          }
        }
      }
    },
    "about.avoid.title": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was Wir Vermeiden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What We Avoid"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo Que Evitamos"
          }
        }
      }
    },
    "about.avoid.tooltip": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tooltip-Abhängigkeit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tooltip dependency"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dependencia de tooltips"
          }
        }
      }
    },
    "about.hero.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir bauen Werkzeuge für das langfristige Web — Software, die das Handwerk der Entwicklung und die Geduld guten Designs respektiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We build tools for the long-term web — software that respects the craft of development and the patience of good design."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construimos herramientas para la web a largo plazo — software que respeta el oficio del desarrollo y la paciencia del buen diseño."
          }
        }
      }
    },
    "about.hero.title": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unsere Philosophie"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Our Philosophy"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nuestra Filosofía"
          }
        }
      }
    },
    "about.principle.composition": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komposition statt Vererbung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Composition over inheritance"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Composición sobre herencia"
          }
        }
      }
    },
    "about.principle.composition.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komplexes Verhalten aus kleinen, vorhersehbaren Teilen aufbauen statt tiefer Klassenhierarchien."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Build complex behavior from small, predictable parts rather than deep class hierarchies."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construye comportamiento complejo a partir de partes pequeñas y predecibles en lugar de jerarquías profundas de clases."
          }
        }
      }
    },
    "about.principle.convention": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konvention statt Konfiguration"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Convention over configuration"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convención sobre configuración"
          }
        }
      }
    },
    "about.principle.convention.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sinnvolle Standardwerte, die 90% der Fälle abdecken. Ausweichmöglichkeiten für den Rest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensible defaults that cover 90% of cases. Escape hatches for the rest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Valores predeterminados sensatos que cubren el 90% de los casos. Vías de escape para el resto."
          }
        }
      }
    },
    "about.principle.durability": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Haltbarkeit statt Neuheit"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Durability over novelty"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Durabilidad sobre novedad"
          }
        }
      }
    },
    "about.principle.durability.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie langweilige Technologie, die zuverlässig funktioniert, statt glänzender Tools, die möglicherweise nicht bestehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose boring technology that works reliably over shiny tools that may not last."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige tecnología aburrida que funcione de forma fiable sobre herramientas brillantes que pueden no durar."
          }
        }
      }
    },
    "about.principle.integration": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertikale Integration statt Klebstoff"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vertical integration over glue"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Integración vertical sobre pegamento"
          }
        }
      }
    },
    "about.principle.integration.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den gesamten Stack vom Quellcode bis zur Bereitstellung besitzen. Weniger Nahtstellen, weniger Fehler."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Own the full stack from source to deployment. Fewer seams, fewer bugs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla todo el stack desde el código fuente hasta el despliegue. Menos uniones, menos errores."
          }
        }
      }
    },
    "about.principle.static": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statische Analyse statt Laufzeitprüfungen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Static analysis over runtime checks"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Análisis estático sobre verificaciones en ejecución"
          }
        }
      }
    },
    "about.principle.static.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fehler zur Kompilierzeit erkennen. Typsicherheit ist die erste Verteidigungslinie."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Catch errors at compile time. Type safety is the first line of defense."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detecta errores en tiempo de compilación. La seguridad de tipos es la primera línea de defensa."
          }
        }
      }
    },
    "about.principle.transparency": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparenz statt Magie"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparency over magic"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Transparencia sobre magia"
          }
        }
      }
    },
    "about.principle.transparency.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Abstraktion sollte inspizierbar sein. Kein verstecktes Laufzeitverhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every abstraction should be inspectable. No hidden runtime behavior."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toda abstracción debe ser inspeccionable. Sin comportamiento oculto en tiempo de ejecución."
          }
        }
      }
    },
    "about.standard.docs": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dokumentation ist Produkt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Docs are product"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La documentación es producto"
          }
        }
      }
    },
    "about.standard.docs.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dokumentation ist kein Nachgedanke. Sie wird mit dem Feature ausgeliefert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Documentation is not an afterthought. It ships with the feature."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La documentación no es un pensamiento posterior. Se envía con la funcionalidad."
          }
        }
      }
    },
    "about.standard.feedback": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sofortiges Feedback"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Immediate feedback"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Retroalimentación inmediata"
          }
        }
      }
    },
    "about.standard.feedback.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Aktion sollte innerhalb von Millisekunden ein sichtbares Ergebnis liefern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every action should produce a visible result within milliseconds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada acción debe producir un resultado visible en milisegundos."
          }
        }
      }
    },
    "about.standard.floor": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Niedrige Einstiegshürde, hohe Decke"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Low floor, high ceiling"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Piso bajo, techo alto"
          }
        }
      }
    },
    "about.standard.floor.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einfach zu starten, leistungsfähig genug für Produktion. Keine Stützräder, die im Weg stehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Easy to start, powerful enough for production. No training wheels that get in the way."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fácil de empezar, lo suficientemente potente para producción. Sin ruedas de entrenamiento que estorben."
          }
        }
      }
    },
    "about.standard.zeroconfig": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Konfiguration standardmäßig"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Zero config by default"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin configuración por defecto"
          }
        }
      }
    },
    "about.standard.zeroconfig.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit sinnvollen Standardwerten ausliefern. Konfiguration ist für Änderungen, nicht für die Einrichtung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ship with sensible defaults. Configuration is for overrides, not setup."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía con valores predeterminados sensatos. La configuración es para sobreescrituras, no para inicialización."
          }
        }
      }
    },
    "about.standards.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie wir über die Erfahrungsebene denken — die Schnittstelle zwischen Werkzeug und Mensch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How we think about the experience layer — the interface between tool and human."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cómo pensamos sobre la capa de experiencia — la interfaz entre herramienta y humano."
          }
        }
      }
    },
    "about.standards.title": {
      "localizations": {
