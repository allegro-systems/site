          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See changes rendered in real-time as you build. What you see is what ships to production."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve los cambios renderizados en tiempo real mientras construyes. Lo que ves es lo que se publica en producción."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотрите изменения в реальном времени, пока вы создаёте. Что видите — то и отправляется в продакшен."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi le modifiche renderizzate in tempo reale mentre costruisci. Quello che vedi è quello che va in produzione."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez les changements rendus en temps réel pendant que vous construisez. Ce que vous voyez est ce qui part en production."
          }
        }
      }
    },
