    "score.hero.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Webanwendungen komplett in Swift erstellen.\nResult-Builder für Layout. Signale für State. Ein Befehl zum Ausliefern."
          }
        },
        "en": {
