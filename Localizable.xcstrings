            "value": "Cada acción debe producir un resultado visible en milisegundos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждое действие должно давать видимый результат в течение миллисекунд."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
