    "score.feature.deploy.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine statische Website generieren oder einen Live-Server aus derselben Codebasis betreiben. Ein Befehl in jedem Fall."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generate a static site or run a live server from the same codebase. One command either way."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Genera un sitio estático o ejecuta un servidor en vivo desde la misma base de código. Un comando en cualquier caso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Генерируйте статический сайт или запускайте живой сервер из одной кодовой базы. Одна команда в любом случае."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Genera un sito statico o esegui un server live dalla stessa codebase. Un solo comando in entrambi i casi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Générez un site statique ou lancez un serveur live depuis la même base de code. Une seule commande dans les deux cas."
          }
        }
      }
    },
