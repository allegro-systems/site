            "state": "translated",
            "value": "Visual-First Onboarding  ·  Single-Worker Model  ·  Deterministic Builds via Stage"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incorporación Visual  ·  Modelo de Trabajador Único  ·  Compilaciones Determinísticas via Stage"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Визуальный онбординг  ·  Модель одного воркера  ·  Детерминированные сборки через Stage"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
