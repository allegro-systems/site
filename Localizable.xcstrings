    "libretto.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Blogging-Plattform für Entwickler und technische Autoren — angetrieben von Score und Stage. Ein reichhaltiges Bearbeitungserlebnis, ablenkungsfrei, und darauf ausgelegt, Ihre Ideen zu den richtigen Menschen zu bringen. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A blogging platform built for developers and technical writers — powered by Score and Stage. A rich editing experience, distraction-free, and designed to let your ideas reach the right people. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una plataforma de blogs para desarrolladores y escritores técnicos — impulsada por Score y Stage. Una experiencia de edición enriquecida, sin distracciones, diseñada para que tus ideas lleguen a las personas adecuadas. Próximamente."
          }
        }
      }
    },
    "libretto.feature.analytics": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Publikumsanalysen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audience Analytics"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Análisis de Audiencia"
