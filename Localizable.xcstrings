    "docs.composer.coming_soon_desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Composer-Dokumentation wird derzeit geschrieben. Schauen Sie bald wieder vorbei für Anleitungen zum visuellen Editor, Canvas-Workflows und Komponentenbibliothek."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Composer documentation is currently being written. Check back soon for guides on the visual editor, canvas workflows, and component library."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La documentación de Composer se está escribiendo actualmente. Vuelve pronto para guías sobre el editor visual, flujos de lienzo y biblioteca de componentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Документация Composer находится в процессе написания. Скоро здесь появятся руководства по визуальному редактору, рабочим процессам холста и библиотеке компонентов."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La documentazione di Composer è in fase di scrittura. Torna presto per guide sull'editor visuale, i flussi di lavoro del canvas e la libreria componenti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
