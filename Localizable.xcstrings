    "composer.feature.canvas.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Layouts mit einem nativen Drag-and-Drop-Editor für macOS und iPad gestalten. Visuell bauen, sauber exportieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Design layouts with a native macOS and iPad drag-and-drop editor. Build visually, export cleanly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseña maquetaciones con un editor nativo de arrastrar y soltar para macOS e iPad. Construye visualmente, exporta limpiamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проектируйте макеты с помощью нативного редактора macOS и iPad с перетаскиванием. Создавайте визуально, экспортируйте чисто."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Progetta layout con un editor drag-and-drop nativo per macOS e iPad. Costruisci visivamente, esporta in modo pulito."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Concevez des mises en page avec un éditeur glisser-déposer natif macOS et iPad. Construisez visuellement, exportez proprement."
          }
        }
      }
    },
