    },
    "composer.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein nativer visueller Editor für macOS und iPad, mit dem Sie Score-Projekte ohne Code entwerfen und erstellen können. Drag-and-Drop-Komponenten, Live-Vorschau und deterministische Produktions-Builds powered by Stage. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A native visual editor for macOS and iPad that lets you design and build Score projects without writing code. Drag-and-drop components, live preview, and deterministic production builds powered by Stage. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un editor visual nativo para macOS e iPad que te permite diseñar y construir proyectos Score sin escribir código. Componentes de arrastrar y soltar, vista previa en vivo y compilaciones de producción determinísticas impulsadas por Stage. Próximamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нативный визуальный редактор для macOS и iPad, который позволяет проектировать и создавать проекты Score без написания кода. Перетаскивание компонентов, живой предпросмотр и детерминированные продакшен-сборки на базе Stage. Скоро."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un editor visuale nativo per macOS e iPad che ti permette di progettare e costruire progetti Score senza scrivere codice. Componenti drag-and-drop, anteprima live e build di produzione deterministiche con Stage. In arrivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un éditeur visuel natif pour macOS et iPad qui vous permet de concevoir et construire des projets Score sans écrire de code. Glisser-déposer des composants, aperçu en direct et builds de production déterministes via Stage. Bientôt disponible."
          }
        }
      }
    },
    "composer.feature.canvas": {
      "localizations": {
