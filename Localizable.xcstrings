    "libretto.feature.analytics.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verstehen Sie, wer Ihre Arbeit liest, mit integrierten Statistiken zu Aufrufen, Lese-Dauer und Engagement."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understand who reads your work with built-in stats on views, reads, and engagement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprende quién lee tu trabajo con estadísticas integradas de vistas, lecturas e interacción."
          }
        }
      }
    },
    "libretto.feature.discovery": {
