          "stringUnit": {
            "state": "translated",
            "value": "Sigue escritores, cura listas de lectura y muestra publicaciones a través de etiquetas y recomendaciones."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подписывайтесь на авторов, составляйте списки чтения и находите публикации через теги и рекомендации."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Segui gli scrittori, cura liste di lettura e scopri post tramite tag e raccomandazioni."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez des auteurs, créez des listes de lecture et découvrez des articles via les tags et recommandations."
          }
        }
      }
    },
