    "about.hero.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir bauen Werkzeuge für das langfristige Web — Software, die das Handwerk der Entwicklung und die Geduld guten Designs respektiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We build tools for the long-term web — software that respects the craft of development and the patience of good design."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Construimos herramientas para la web a largo plazo — software que respeta el oficio del desarrollo y la paciencia del buen diseño."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы создаём инструменты для долгосрочного веба — программное обеспечение, которое уважает мастерство разработки и терпение хорошего дизайна."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Costruiamo strumenti per il web a lungo termine — software che rispetta l'arte dello sviluppo e la pazienza del buon design."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous construisons des outils pour le web durable — des logiciels qui respectent l'art du développement et la patience du bon design."
          }
        }
      }
    },
    "about.hero.title": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unsere Philosophie"
          }
        },
        "en": {
