    "libretto.feature.analytics.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verstehen Sie, wer Ihre Arbeit liest, mit integrierten Statistiken zu Aufrufen, Lese-Dauer und Engagement."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understand who reads your work with built-in stats on views, reads, and engagement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprende quién lee tu trabajo con estadísticas integradas de vistas, lecturas e interacción."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Понимайте, кто читает ваши работы, с помощью встроенной статистики просмотров, прочтений и вовлечённости."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scopri chi legge il tuo lavoro con statistiche integrate su visualizzazioni, letture e coinvolgimento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprenez qui lit votre travail grâce aux statistiques intégrées de vues, lectures et engagement."
          }
        }
      }
    },
