    "about.standard.floor.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einfach zu starten, leistungsfähig genug für Produktion. Keine Stützräder, die im Weg stehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Easy to start, powerful enough for production. No training wheels that get in the way."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fácil de empezar, lo suficientemente potente para producción. Sin ruedas de entrenamiento que estorben."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Легко начать, достаточно мощный для продакшена. Никаких ограничителей, которые мешают."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Facile da iniziare, abbastanza potente per la produzione. Nessun limitatore che intralci."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Facile à démarrer, assez puissant pour la production. Pas de garde-fous qui gênent."
          }
