    "about.avoid.motion": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übermäßige dekorative Bewegung"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Excessive Decorative motion"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Movimiento decorativo excesivo"
          }
