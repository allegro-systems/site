    "composer.capabilities": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual-First Onboarding  ·  Single-Worker-Modell  ·  Deterministische Builds via Stage"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual-First Onboarding  ·  Single-Worker Model  ·  Deterministic Builds via Stage"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incorporación Visual  ·  Modelo de Trabajador Único  ·  Compilaciones Determinísticas via Stage"
          }
        }
      }
    },
    "composer.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein nativer visueller Editor für macOS und iPad, mit dem Sie Score-Projekte ohne Code entwerfen und erstellen können. Drag-and-Drop-Komponenten, Live-Vorschau und deterministische Produktions-Builds powered by Stage. Demnächst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A native visual editor for macOS and iPad that lets you design and build Score projects without writing code. Drag-and-drop components, live preview, and deterministic production builds powered by Stage. Coming soon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un editor visual nativo para macOS e iPad que te permite diseñar y construir proyectos Score sin escribir código. Componentes de arrastrar y soltar, vista previa en vivo y compilaciones de producción determinísticas impulsadas por Stage. Próximamente."
          }
        }
      }
    },
    "composer.feature.canvas": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Visueller Canvas-Editor"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual Canvas Editor"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Editor de Lienzo Visual"
          }
        }
      }
    },
    "composer.feature.canvas.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Layouts mit einem nativen Drag-and-Drop-Editor für macOS und iPad gestalten. Visuell bauen, sauber exportieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Design layouts with a native macOS and iPad drag-and-drop editor. Build visually, export cleanly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseña maquetaciones con un editor nativo de arrastrar y soltar para macOS e iPad. Construye visualmente, exporta limpiamente."
          }
        }
      }
    },
    "composer.feature.library": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Komponentenbibliothek"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Component Library"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Biblioteca de Componentes"
          }
        }
      }
    },
    "composer.feature.library.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiederverwendbare Bausteine, die mit Ihrem Score-Projekt synchronisiert werden. Einmal zusammenstellen, überall verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reusable building blocks that sync with your Score project. Compose once, use everywhere."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bloques de construcción reutilizables que se sincronizan con tu proyecto Score. Compone una vez, usa en todas partes."
          }
        }
