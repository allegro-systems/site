      }
    },
    "about.thesis.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sechs Prinzipien, die jede architektonische Entscheidung leiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Six principles that guide every architectural decision we make."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seis principios que guían cada decisión arquitectónica que tomamos."
          }
        }
      }
    },
    "about.thesis.title": {
