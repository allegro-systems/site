            "value": "Ein vertikal integriertes Ökosystem von Werkzeugen für das moderne Web — vom Framework bis zur Bereitstellung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A vertically integrated ecosystem of tools for the modern web — from framework to deployment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ecosistema verticalmente integrado de herramientas para la web moderna — del framework al despliegue."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вертикально интегрированная экосистема инструментов для современного веба — от фреймворка до развёртывания."
          }
        }
      }
    },
