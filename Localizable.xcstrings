            "value": "CSS на основе компилятора"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "CSS Generato dal Compilatore"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CSS Piloté par le Compilateur"
          }
        }
      }
    },
    "score.highlight.css.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier-Ketten kompilieren zu Scope-Klassennamen. Identische Modifier-Sets teilen sich eine einzelne Klasse. Keine Laufzeit-Stillogik."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modifier chains compile to scoped class names. Identical modifier sets share a single class. Zero runtime style logic."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las cadenas de modificadores compilan a nombres de clase con alcance. Conjuntos idénticos comparten una sola clase. Cero lógica de estilos en tiempo de ejecución."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цепочки модификаторов компилируются в изолированные имена классов. Одинаковые наборы модификаторов используют один класс. Никакой логики стилей во время выполнения."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le catene di modificatori compilano in nomi di classi con scope. Set di modificatori identici condividono una singola classe. Zero logica di stile a runtime."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les chaînes de modificateurs compilent en noms de classes scopés. Des ensembles de modificateurs identiques partagent une seule classe. Zéro logique de style au runtime."
          }
        }
      }
    },
    "score.highlight.signals": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Signal-basierte Reaktivität"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signal-Backed Reactivity"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reactividad Basada en Señales"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Реактивность на основе сигналов"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Reattività Basata su Segnali"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réactivité Basée sur les Signaux"
          }
        }
      }
    },
    "score.highlight.signals.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Swift State-Deklarationen kompilieren zu TC39 Signalen. Drei Bereiche: Application (global), Page (wird bei Navigation abgebaut), Element (pro Montage)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swift state declarations lower to TC39 Signals. Three scopes: Application (global), Page (torn down on nav), Element (per mount)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las declaraciones de estado en Swift se compilan a Señales TC39. Tres alcances: Aplicación (global), Página (se destruye al navegar), Elemento (por montaje)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объявления состояния Swift транслируются в TC39 Signals. Три области: Application (глобальная), Page (уничтожается при навигации), Element (при монтировании)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dichiarazioni di stato Swift si traducono in TC39 Signals. Tre scope: Application (globale), Page (distrutto alla navigazione), Element (per mount)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les déclarations d'état Swift se traduisent en TC39 Signals. Trois portées : Application (globale), Page (détruite à la navigation), Element (par montage)."
          }
        }
      }
    },
    "score.highlight.static": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statische Ausgabe Zuerst"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Static-First Output"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salida Estática Primero"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Статика в первую очередь"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Output Statico per Default"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sortie Statique par Défaut"
          }
        }
      }
    },
    "score.highlight.static.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Seiten kompilieren standardmäßig zu byte-äquivalentem HTML + CSS. JS wird nur ausgegeben wenn @State oder @Action verwendet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pages compile to byte-equivalent HTML + CSS by default. JS is only emitted when @State or @Action are used."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las páginas compilan a HTML + CSS equivalente en bytes por defecto. JS solo se emite cuando se usan @State o @Action."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Страницы компилируются в байт-эквивалентный HTML + CSS по умолчанию. JS генерируется только при использовании @State или @Action."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le pagine compilano in HTML + CSS byte-equivalent di default. JS viene emesso solo quando si usano @State o @Action."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pages compilent en HTML + CSS byte-equivalent par défaut. Le JS n'est émis que lorsque @State ou @Action sont utilisés."
          }
        }
      }
    },
