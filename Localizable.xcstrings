    "about.standard.feedback.desc": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Aktion sollte innerhalb von Millisekunden ein sichtbares Ergebnis liefern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every action should produce a visible result within milliseconds."
          }
        },
        "es": {
          "stringUnit": {
