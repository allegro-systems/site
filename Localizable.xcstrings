    "about.avoid.subtitle": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Muster, die wir bewusst ablehnen. Nicht weil sie immer falsch sind,\nsondern weil sie im Widerspruch zu der Erfahrung stehen, die wir aufbauen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Patterns we consciously reject. Not because they're always wrong,\nbut because they conflict with the experience we're building."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrones que rechazamos conscientemente. No porque siempre estén mal,\nsino porque entran en conflicto con la experiencia que estamos construyendo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Паттерны, которые мы сознательно отвергаем. Не потому, что они всегда неправильны,\nа потому, что они противоречат опыту, который мы создаём."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pattern che rifiutiamo consapevolmente. Non perché siano sempre sbagliati,\nma perché sono in conflitto con l'esperienza che stiamo costruendo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des patterns que nous rejetons consciemment. Non pas parce qu'ils sont toujours mauvais,\nmais parce qu'ils entrent en conflit avec l'expérience que nous construisons."
          }
        }
      }
    },
